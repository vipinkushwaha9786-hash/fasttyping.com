<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monkeytype Ultimate Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@300;400;500&display=swap');
        :root { --bg: #323437; --main: #e2b714; --sub: #646669; --text: #d1d0c5; --err: #ca4754; }
        body { background: var(--bg); color: var(--sub); font-family: 'Roboto Mono', monospace; overflow: hidden; }
        
        /* Typography & Smoothness */
        .letter { transition: color 0.1s ease; position: relative; }
        .letter.correct { color: var(--text); }
        .letter.incorrect { color: var(--err); border-bottom: 2px solid var(--err); }
        
        /* Smooth Caret Fix */
        #caret { 
            width: 2px; height: 1.5rem; background: var(--main); 
            position: absolute; z-index: 10;
            transition: left 0.1s cubic-bezier(0.175, 0.885, 0.32, 1.275), top 0.1s ease; 
        }
        .blink { animation: blinker 1s step-end infinite; }
        @keyframes blinker { 50% { opacity: 0; } }

        .config-btn.active { color: var(--main); }
        #words-container { transition: margin-top 0.25s ease; user-select: none; }
        .hidden { display: none !important; }
    </style>
</head>
<body class="flex flex-col min-h-screen items-center p-6 md:p-12">

    <!-- Header -->
    <header class="w-full max-w-5xl flex justify-between mb-8 opacity-80">
        <div class="flex items-center gap-3 text-xl font-bold text-[#d1d0c5] cursor-pointer" onclick="init()">
            <i class="fas fa-keyboard text-[#e2b714]"></i> monkeytype
        </div>
        <div class="flex gap-4 text-sm items-center">
            <span class="text-xs">PB: <span id="pb-display" class="text-[#e2b714]">0</span></span>
            <i class="fas fa-cog"></i> <i class="fas fa-user"></i>
        </div>
    </header>

    <!-- Config Menu -->
    <nav id="config-menu" class="bg-[rgba(0,0,0,0.1)] px-6 py-2 rounded-lg flex gap-6 text-xs mb-16 transition-opacity">
        <div class="flex gap-4 border-r border-gray-700 pr-6">
            <span id="mode-time" class="config-btn active cursor-pointer" onclick="setMode('time')">time</span>
            <span id="mode-words" class="config-btn cursor-pointer" onclick="setMode('words')">words</span>
        </div>
        <div id="options-container" class="flex gap-4">
            <!-- Dynamic Options -->
        </div>
    </nav>

    <!-- Typing Section -->
    <main id="typing-section" class="w-full max-w-5xl">
        <div id="live-stat" class="text-2xl text-[#e2b714] mb-6 h-8 opacity-0">30</div>
        <input type="text" id="hidden-input" class="absolute opacity-0 pointer-events-none" autocomplete="off" spellcheck="false">
        
        <div id="typing-area" class="relative text-2xl md:text-3xl leading-relaxed h-[140px] overflow-hidden cursor-text">
            <div id="caret" class="blink"></div>
            <div id="words-container" class="flex flex-wrap content-start"></div>
        </div>

        <div class="mt-20 text-center text-xs opacity-40">
            <i class="fas fa-redo mb-4 text-xl cursor-pointer hover:text-white" onclick="init()"></i><br>
            <span class="bg-[#444] px-2 py-1 rounded">Tab</span> to restart
        </div>
    </main>

    <!-- Result Dashboard -->
    <div id="result-section" class="w-full max-w-6xl hidden">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
            <div class="md:col-span-2 flex flex-col gap-8">
                <div><div class="text-xl opacity-50">wpm</div><div id="res-wpm" class="text-7xl font-bold text-[#e2b714]">0</div></div>
                <div><div class="text-xl opacity-50">acc</div><div id="res-acc" class="text-7xl font-bold text-[#e2b714]">0%</div></div>
            </div>
            <div class="md:col-span-10 h-[250px]"><canvas id="resultChart"></canvas></div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-16 text-center border-t border-[#3e4042] pt-8">
            <div><div class="text-xs opacity-50 uppercase tracking-widest">test type</div><div id="res-type" class="text-[#e2b714] text-lg"></div></div>
            <div><div class="text-xs opacity-50 uppercase tracking-widest">raw</div><div id="res-raw" class="text-4xl text-[#d1d0c5]">0</div></div>
            <div><div class="text-xs opacity-50 uppercase tracking-widest">characters</div><div id="res-chars" class="text-4xl text-[#e2b714]">0/0/0/0</div></div>
            <div><div class="text-xs opacity-50 uppercase tracking-widest">consistency</div><div id="res-consistency" class="text-4xl text-[#d1d0c5]">0%</div></div>
        </div>
    </div>

    <script>
        const wordsList = "the quick brown fox jumps over the lazy dog child form play come never against those you open real leave out high head without they with life get small home world line system point set state school house city group side".split(" ");
        
        let config = { mode: 'time', value: 30 };
        let state = {
            charIndex: 0,
            isStarted: false,
            timer: null,
            startTime: null,
            history: [], // WPM samples for graph & consistency
            correct: 0,
            incorrect: 0,
            rawTyped: 0
        };

        const input = document.getElementById('hidden-input');
        const container = document.getElementById('words-container');
        const caret = document.getElementById('caret');
        const liveStat = document.getElementById('live-stat');

        // Audio Context (Feedback)
        const playSound = (freq, type = 'sine', duration = 0.05) => {
            const ctx = new (window.AudioContext || window.webkitAudioContext)();
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.type = type;
            osc.frequency.setValueAtTime(freq, ctx.currentTime);
            gain.gain.setValueAtTime(0.1, ctx.currentTime);
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start();
            osc.stop(ctx.currentTime + duration);
        };

        function init() {
            // Reset State
            clearInterval(state.timer);
            Object.assign(state, { charIndex: 0, isStarted: false, timer: null, startTime: null, history: [], correct: 0, incorrect: 0, rawTyped: 0 });
            
            // UI Resets
            document.getElementById('typing-section').classList.remove('hidden');
            document.getElementById('result-section').classList.add('hidden');
            document.getElementById('config-menu').style.opacity = '1';
            liveStat.style.opacity = '0';
            liveStat.innerText = config.value;
            input.value = '';
            container.style.marginTop = '0px';
            caret.classList.add('blink');
            
            // PB Display
            document.getElementById('pb-display').innerText = localStorage.getItem('monkeyPB') || 0;

            // Render Words
            renderWords();
            renderConfig();
            updateCaret();
        }

        function renderWords() {
            container.innerHTML = '';
            const wordCount = config.mode === 'words' ? config.value : 100;
            for(let i=0; i < wordCount; i++) {
                const word = wordsList[Math.floor(Math.random() * wordsList.length)];
                const wordDiv = document.createElement('div');
                wordDiv.className = 'word flex mr-3 mb-2';
                
                word.split('').forEach(l => {
                    const span = document.createElement('span');
                    span.className = 'letter';
                    span.innerText = l;
                    wordDiv.appendChild(span);
                });
                
                // CRITICAL FIX: Add Space as a letter
                const space = document.createElement('span');
                space.className = 'letter';
                space.innerHTML = '&nbsp;';
                wordDiv.appendChild(space);
                
                container.appendChild(wordDiv);
            }
        }

        function renderConfig() {
            const optCont = document.getElementById('options-container');
            optCont.innerHTML = '';
            const vals = config.mode === 'time' ? [15, 30, 60] : [10, 25, 50];
            vals.forEach(v => {
                const span = document.createElement('span');
                span.className = `config-btn cursor-pointer ${config.value == v ? 'active' : ''}`;
                span.innerText = v;
                span.onclick = () => { config.value = v; init(); };
                optCont.appendChild(span);
            });
        }

        function updateCaret() {
            const letters = document.querySelectorAll('.letter');
            const target = letters[state.charIndex];
            if (target) {
                caret.style.left = target.offsetLeft + "px";
                caret.style.top = (target.offsetTop + 4) + "px";
                if(target.offsetTop > 40) container.style.marginTop = `-${target.offsetTop - 5}px`;
            }
        }

        function startTest() {
            state.startTime = Date.now();
            liveStat.style.opacity = '1';
            document.getElementById('config-menu').style.opacity = '0';
            caret.classList.remove('blink');

            state.timer = setInterval(() => {
                let elapsed = (Date.now() - state.startTime) / 1000;
                let curWpm = Math.round((state.correct / 5) / (elapsed / 60)) || 0;
                state.history.push(curWpm);

                if (config.mode === 'time') {
                    let remaining = config.value - Math.floor(elapsed);
                    liveStat.innerText = remaining;
                    if (remaining <= 0) finishTest();
                } else {
                    // Logic fix: Correct word mode counting
                    let wordsTyped = Math.floor(state.charIndex / 6); // Avg 5 letters + space
                    liveStat.innerText = `${wordsTyped}/${config.value}`;
                    if (wordsTyped >= config.value) finishTest();
                }
            }, 1000);
        }

        input.addEventListener('keydown', (e) => {
            if (e.key === "Tab") { e.preventDefault(); init(); return; }
            
            const letters = document.querySelectorAll('.letter');
            
            // Backspace Logic (FIX #2)
            if (e.key === "Backspace") {
                if (state.charIndex > 0) {
                    state.charIndex--;
                    const prev = letters[state.charIndex];
                    if (prev.classList.contains('correct')) state.correct--;
                    else if (prev.classList.contains('incorrect')) state.incorrect--;
                    prev.classList.remove('correct', 'incorrect');
                    updateCaret();
                }
                return;
            }

            // Normal Typing
            if (e.key.length === 1 && !e.ctrlKey && !e.metaKey) {
                if (!state.isStarted) { startTest(); state.isStarted = true; }

                const expected = letters[state.charIndex].innerText.replace('\u00A0', ' ');
                const typed = e.key;

                state.rawTyped++;
                if (typed === expected) {
                    letters[state.charIndex].classList.add('correct');
                    state.correct++;
                    playSound(440, 'sine', 0.02); // Key feedback
                } else {
                    letters[state.charIndex].classList.add('incorrect');
                    state.incorrect++;
                    playSound(200, 'triangle', 0.05); // Error feedback
                }

                state.charIndex++;
                updateCaret();
                
                // Auto finish word mode
                if(config.mode === 'words' && state.charIndex >= letters.length) finishTest();
            }
        });

        function finishTest() {
            clearInterval(state.timer);
            document.getElementById('typing-section').classList.add('hidden');
            document.getElementById('result-section').classList.remove('hidden');
            
            const finalWpm = state.history[state.history.length - 1] || 0;
            const finalAcc = Math.round((state.correct / state.rawTyped) * 100) || 0;
            
            // Consistency Calculation (WPM Variance)
            const mean = state.history.reduce((a,b) => a+b, 0) / state.history.length;
            const variance = state.history.reduce((a,b) => a + Math.pow(b - mean, 2), 0) / state.history.length;
            const consistency = Math.max(0, 100 - Math.round(Math.sqrt(variance) * 2));

            document.getElementById('res-wpm').innerText = finalWpm;
            document.getElementById('res-acc').innerText = finalAcc + "%";
            document.getElementById('res-type').innerText = `${config.mode} ${config.value}`;
            document.getElementById('res-raw').innerText = Math.round((state.rawTyped / 5) / ((config.mode === 'time' ? config.value : state.history.length) / 60));
            document.getElementById('res-chars').innerText = `${state.correct}/${state.incorrect}/0/0`;
            document.getElementById('res-consistency').innerText = consistency + "%";

            // Save PB
            const currentPB = localStorage.getItem('monkeyPB') || 0;
            if (finalWpm > currentPB) localStorage.setItem('monkeyPB', finalWpm);

            renderChart();
        }

        function renderChart() {
            const ctx = document.getElementById('resultChart');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: state.history.map((_, i) => i + 1),
                    datasets: [{
                        label: 'WPM',
                        data: state.history,
                        borderColor: '#e2b714',
                        tension: 0.4,
                        fill: true,
                        backgroundColor: 'rgba(226,183,20,0.1)'
                    }]
                },
                options: { 
                    responsive: true, 
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, grid: { color: '#3e4042' } }, x: { display: false } }
                }
            });
        }

        function setMode(m) { config.mode = m; config.value = m === 'time' ? 30 : 25; init(); }
        
        document.body.addEventListener('click', () => input.focus());
        window.onload = init;
    </script>
</body>
</html>
